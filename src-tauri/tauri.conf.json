{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "debug.online",
  "version": "0.1.0",
  "identifier": "online.debug.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "debug.online",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm"],
    "category": "DeveloperTool",
    "shortDescription": "Fast IT toolkit — DNS, SSL, JWT, JSON, regex and more.",
    "longDescription": "debug.online is a free, fast, browser-style toolkit packaged for Linux. 23 utilities for developers and IT professionals — JSON formatter, JWT decoder, regex tester, DNS lookup, SSL inspector, hash generator, and more — with optional AI-powered Smart Context explanations.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
