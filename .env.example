# Smart Context — AI insights (optional, falls back to a friendly message)
ANTHROPIC_API_KEY=

# Share snapshots — Vercel KV REST credentials. Without these, share links
# work in-process for local dev but won't survive a serverless cold start.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Carbon Ads serve code (optional, ad slot is hidden when unset)
VITE_CARBON_SERVE=
